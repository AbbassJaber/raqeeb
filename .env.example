# Copy to .env and fill in to enable the online (live) paths.
RAQEEB_OFFLINE=0

# --- LLM provider (pick ONE) ------------------------------------------------
# Anthropic Claude (https://console.anthropic.com) — the default provider; selected
# whenever this key is set:
ANTHROPIC_API_KEY=sk-ant-...
# Or Gemini (free, Google AI Studio: https://aistudio.google.com/apikey) — used only
# when no Anthropic key is set:
# GEMINI_API_KEY=AIza...
# Force a provider explicitly (otherwise auto-detected): claude | gemini
# RAQEEB_LLM=claude
# Optional model overrides:
# RAQEEB_MODEL=claude-sonnet-4-6
# RAQEEB_GEMINI_MODEL=gemini-2.5-flash

# --- Earth Engine -----------------------------------------------------------
# Run `earthengine authenticate` once, then set your Google Cloud project id:
EARTHENGINE_PROJECT=your-gcp-project-id

# --- Reviewer handoff (alerts are DRAFTED; a human reviews & sends) ---------
# Transport: outbox (default, writes outputs/outbox/, no creds) | email | webhook
# RAQEEB_REVIEW_TRANSPORT=outbox
# Email (SMTP) transport:
# RAQEEB_REVIEWER_EMAIL=reviewer@example.org
# RAQEEB_SMTP_HOST=smtp.example.org
# RAQEEB_SMTP_PORT=587
# RAQEEB_SMTP_USER=you@example.org
# RAQEEB_SMTP_PASSWORD=app-password
# Webhook transport (e.g. Slack/Teams incoming webhook):
# RAQEEB_REVIEW_WEBHOOK=https://hooks.slack.com/services/XXX/YYY/ZZZ

# --- Docker Compose (live profile only) -------------------------------------
# Host folder holding the `credentials` file from `earthengine authenticate`,
# mounted read-only into the container. Used only by `docker compose --profile live`.
#   Windows: C:/Users/<you>/.config/earthengine
#   macOS/Linux: ~/.config/earthengine
# EARTHENGINE_CREDS=C:/Users/you/.config/earthengine
